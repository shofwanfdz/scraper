# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=scraping_db
DB_USER=root
DB_PASSWORD=

# Proxy Configuration (optional)
PROXY_LIST_URL=
PROXY_API_KEY=

# CAPTCHA Solver (optional)
CAPTCHA_API_KEY=
CAPTCHA_SERVICE=2captcha

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
DEFAULT_DELAY_MIN=1
DEFAULT_DELAY_MAX=3
MAX_CONCURRENT_REQUESTS=5
MAX_RETRIES=3

# Export Settings
EXPORT_DIR=./exports
